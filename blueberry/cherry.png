        <div style="padding-bottom: 2em;"></div>

        <script>
            {
                const el = createEl(MainMenu(createMainMenu()));
                // const el = createEl(FullMenu({}));
                document.getElementById("the-menu").appendChild(el);
            }
            {
                const el = createEl(TodaysSpecialMenu({}));
                document.getElementById("todays-special-menu").appendChild(el);
            }
            // {
            //     const el = createEl(WeeksSpecialMenu({}));
            //     document.getElementById("weeks-special-menu").appendChild(el);
            // }

            const now = new Date();
            handlePurchaseUrl(now);
            {
                if (!checkForPlus(now)) {
                    document.getElementById("no-plus").style.display = "";
                } else {
                    document.getElementById("plus-checkmark").style.display = "";
                    document.getElementById("plus-checkmark").textContent = `${getPlusYear()} ✓`;
                    const plusDaysRemaining = getPlusDaysRemaining(now);
                    const warn = plusDaysRemaining <= 31;
                    document.getElementById("plus-ok").style.display = warn ? "none" : "";
                    document.getElementById("plus-warn").style.display = warn ? "" : "none";
                }
            }
        </script>
    </body>

