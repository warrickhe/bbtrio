        <h3 id="puzzles">Daily Puzzles</h3>
        <p>
            Solve on your phone, tablet, or computer:
        </p>
        <div id="the-menu"></div>
        
        <h3 style="display: none;">Today's Special</h3>
        <div style="display: none;" id="todays-special-menu"></div>

        <!-- <h3>This Week's Special</h3>
        <div id="weeks-special-menu"></div> -->

        <p>
            There are new puzzles every day. Come back tomorrow for more!
        </p>

        <h3 id="plus">Plus <span id="plus-checkmark" style="display: none;"></span></h3>
        <div id="no-plus" style="display: none;">
            <!-- <p>
                Want more of your favorite puzzles?
            </p> -->
            <div class="game-links" style="justify-content: left;">
                <a class="game-link plus-link" href="https://ko-fi.com/s/1ed5315332">
                    <div class="game-title" style="padding-left: 20px;">Upgrade to Plus 2026</div>
                </a>
            </div>
            <p>
                 Plus members gain access to unlimited additional puzzles throughout the year. 
            </p>
        </div>
        <div id="plus-ok" style="display: none;">
            <p>
                <span style="font-weight: bold;"> 
                You are upgraded to Plus.</span>
            </p>
            <p>
                After solving the <b>Daily</b> puzzles, select <b>Plus</b>.<br>
                Press the <b>+1</b> button for even more puzzles!
            </p>
        </div>
        <div id="plus-warn" style="display: none;">
            <p>
                <b>You are upgraded to Plus.</b>
            </p>
            <p>
                <b>2025 will soon end.</b> Please consider purchasing Plus 2026 for the new year! 🎄
            </p>
            <div class="game-links" style="justify-content: left;">
                <a class="game-link plus-link" href="https://ko-fi.com/s/1ed5315332">
                    <div class="game-title" style="padding-left: 20px;">Get Plus 2026</div>
                </a>
            </div>
        </div>
        <p>
            <i>This website does not contain ads.</i>
            Thank you for your support.
        </p>

        <!-- <h3 id="puzzles">Puzzle Packs</h3> -->
