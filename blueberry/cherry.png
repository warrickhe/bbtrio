    <body style="box-sizing: border-box;">
        <div style="display: flex; flex-direction: row; flex-wrap: wrap; justify-content: left; color: var(--theme-text);">
            <a href="/" class="unstyled-link">
                <div style="display: flex; align-items: center;">
                    <div style="font-family: TitleFont; font-size: 35px; font-weight: normal;">CIRCLE</div>
                    <img alt="" src="images/icon-moon-shell.svg?v=414" style="padding: 10px; width: 45px; height: auto;">
                    <div style="font-family: TitleFont; font-size: 35px; font-weight: normal;">MOON</div>
